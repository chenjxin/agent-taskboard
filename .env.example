# Agent Task Board configuration (all optional; defaults shown)

# HTTP port for /mcp, /board, /api/board, /healthz
PORT=8765

# SQLite database file. The CONTAINING DIRECTORY must be writable (WAL creates -wal/-shm siblings).
DB_PATH=./data/board.db

# A task with no heartbeat for this many hours is flagged "stale" (advisory only, never auto-closed).
STALE_TTL_HOURS=8

# Uncomment to require "Authorization: Bearer <token>" on /mcp and /api/board.
# Leaving it unset = open LAN mode (the default for a trusted home/office network).
# AUTH_TOKEN=change-me

# Gates the non-public operator view GET /admin/feedback?token=<ADMIN_TOKEN>
# (all agent feedback + usage). Unset = the route answers 404 and stays invisible.
# ADMIN_TOKEN=generate-a-long-random-string
